<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE xml>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="robot1">

  <xacro:property name="BASE_HEIGHT" value="0.09025" />
  <xacro:property name="BASE_RADIUS" value="0.1" />
  
  <xacro:property name="L1_HEIGHT" value="0.02" />
  <xacro:property name="L1_RADIUS" value="0.09" />

  <xacro:property name="L2_HEIGHT" value="0.25" />
  <xacro:property name="L2_RADIUS" value="0.08" />

  <xacro:property name="L3_HEIGHT" value="0.17155" />
  <xacro:property name="L3_RADIUS" value="0.07" />
  
  <xacro:property name="L4_HEIGHT" value="0.07845" />
  <xacro:property name="L4_RADIUS" value="0.06" />

  <xacro:property name="L5_HEIGHT" value="0.065" />
  <xacro:property name="L5_RADIUS" value="0.05" />

  <xacro:property name="L6_HEIGHT" value="0.066" />
  <xacro:property name="L6_RADIUS" value="0.04" />

  <xacro:property name="eesize" value="0.04315" />


  <xacro:property name="J1_MIN" value="${radians(-180)}" />
  <xacro:property name="J1_MAX" value="${radians(180)}" />

  <xacro:property name="J2_MIN" value="${radians(-108)}" />
  <xacro:property name="J2_MAX" value="${radians(114)}" />

  <xacro:property name="J3_MIN" value="${radians(-123)}" />
  <xacro:property name="J3_MAX" value="${radians(92)}" />

  <xacro:property name="J4_MIN" value="${radians(-180)}" />
  <xacro:property name="J4_MAX" value="${radians(180)}" />

  <xacro:property name="J5_MIN" value="${radians(-100)}" />
  <xacro:property name="J5_MAX" value="${radians(123)}" />

  <xacro:property name="J6_MIN" value="${radians(-180)}" />
  <xacro:property name="J6_MAX" value="${radians(180)}" />

  <material name="blue">
    <color rgba="0.2 0.4 0.65 1" />
  </material>

  <material name="yellow">
    <color rgba="1 0.85 0 1" />
  </material>

  <link name="world" />

  <link name="base">
    <visual name="base">
      <origin xyz="0 0 ${(BASE_HEIGHT)/2}" />
      <geometry>
        <cylinder radius="${BASE_RADIUS}" length="${BASE_HEIGHT}" />
      </geometry>
      <material name="blue" />
    </visual>
  </link>


  <link name="link1">
    <visual name="link1">
      <origin xyz="0 0 ${(L1_HEIGHT)/2}" />
      <geometry>
        <cylinder radius="${L1_RADIUS}" length="${L1_HEIGHT}" />
      </geometry>
      <material name="blue" />
    </visual>
  </link>

  <link name="link2">
    <visual name="link2">
      <origin xyz="0 0 ${(L2_HEIGHT)/2}" />
      <geometry>
        <box size="${L2_RADIUS} ${L2_RADIUS} ${L2_HEIGHT}" />
      </geometry>
      <material name="blue" />
    </visual>
  </link>


  <link name="link3">
    <visual name="link3">
      <origin xyz="${(L3_HEIGHT)/2} 0 0" />
      <geometry>
        <box size="${L3_HEIGHT} ${L3_RADIUS} ${L3_RADIUS}" />
      </geometry>
      <material name="blue" />
    </visual>
  </link>


  <link name="link4">
    <visual name="link4">
      <origin xyz="${(L4_HEIGHT)/2} 0 0" />
      <geometry>
        <box size="${L4_HEIGHT} ${L4_RADIUS} ${L4_RADIUS}" />
      </geometry>
      <material name="blue" />
    </visual>
  </link>


  <link name="link5">
    <visual name="link5">
       <origin xyz="${(L5_HEIGHT)/2} 0 0" />
      <geometry>
        <box size="${L5_HEIGHT} ${L5_RADIUS} ${L5_RADIUS}" />
      </geometry>
      <material name="blue" />
    </visual>
  </link>


  <link name="link6">
    <visual name="link6">
      <origin xyz="${(L6_HEIGHT)/2} 0 0" />
      <geometry>
        <box size="${L6_HEIGHT} ${L6_RADIUS} ${L6_RADIUS}" />
      </geometry>
      <material name="blue" />
    </visual>
  </link>


  <link name="ee">
    <visual name="ee">
      <origin xyz="0 0 0" />
      <geometry>
        <box size="${eesize} ${eesize} ${eesize}" />
      </geometry>
      <material name="yellow" />
    </visual>
  </link>

  <joint name="base_in_world" type="fixed">
    <parent link="world" />
    <child link="base" />
  </joint>

  <joint name="joint1" type="revolute">
    <parent link="base" />
    <child link="link1" />
    <origin xyz="0 0 ${BASE_HEIGHT}" rpy="0 0 0" />
    <axis xyz="0 0 1" />
    <limit lower="${J1_MIN}" upper="${J1_MAX}" effort="1" velocity="1" />
  </joint>

  <joint name="joint2" type="revolute">
    <parent link="link1" />
    <child link="link2" />
    <origin xyz="0 0 ${L1_HEIGHT}" rpy="0 0 0" />
    <axis xyz="0 ${-1} 0" />
    <limit lower="${J2_MIN}" upper="${J2_MAX}" effort="1" velocity="1" />
  </joint>

 <joint name="joint3" type="revolute">
    <parent link="link2" />
    <child link="link3" />
    <origin xyz="0 0 ${L2_HEIGHT}" rpy="0 0 0" />
    <axis xyz="0 ${-1} 0" />
    <limit lower="${J3_MIN}" upper="${J3_MAX}" effort="1" velocity="1" />
  </joint>

 <joint name="joint4" type="revolute">
    <parent link="link3" />
    <child link="link4" />
    <origin xyz="${L3_HEIGHT} 0 0" rpy="0 0 0" />
    <axis xyz="1 0 0" />
    <limit lower="${J4_MIN}" upper="${J4_MAX}" effort="1" velocity="1" />
  </joint>


 <joint name="joint5" type="revolute">
    <parent link="link4" />
    <child link="link5" />
    <origin xyz="${L4_HEIGHT} 0 0" rpy="0 0 0" />
    <axis xyz="0 ${-1} 0" />
    <limit lower="${J5_MIN}" upper="${J5_MAX}" effort="1" velocity="1" />
  </joint>

 <joint name="joint6" type="revolute">
    <parent link="link5" />
    <child link="link6" />
    <origin xyz="${L5_HEIGHT} 0 0" rpy="0 0 0" />
    <axis xyz="1 0 0" />
    <limit lower="${J6_MIN}" upper="${J6_MAX}" effort="1" velocity="1" />
  </joint>

  <joint name="ee_in_link6" type="fixed">
    <parent link="link6" />
    <child link="ee" />
    <origin xyz="${L6_HEIGHT} 0 0" rpy="0 0 0" />
  </joint>

</robot>